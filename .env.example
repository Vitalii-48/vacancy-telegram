# ──────────────────────────────────────────────────────────────
# Vacancy Scanner — конфігурація
# Скопіюйте у .env і заповніть своїми даними
# ──────────────────────────────────────────────────────────────

# 1. Отримати на https://my.telegram.org → "API development tools"
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# 2. Токен вашого бота (від @BotFather)
BOT_TOKEN=123456789:ABCdef...

# 3. Ваш особистий Telegram chat_id
#    Дізнатись: запустіть бота, напишіть /start → він покаже ваш id
NOTIFY_CHAT_ID=123456789

# 4. PostgreSQL
DATABASE_URL=postgresql://vacancy_user:your_password@localhost:5432/vacancy_db

# 5. Канали через кому
CHANNELS=@djinni_jobs,@python_jobs_ua,@it_vacancies_ukraine

# 6. Ключові слова (через кому, lowercase)
KEYWORDS=junior python,junior developer,junior dev,джуніор python,python junior,джун python,стажер python,intern python,trainee python

# 7. Слова-виключення
ANTI_KEYWORDS=senior,lead,middle

# 8. Інтервал сканування в годинах
SCAN_INTERVAL_HOURS=2
